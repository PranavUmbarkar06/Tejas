{
  "manifest_version": 3,
  "name": "AuraAI Intent Tracker",
  "version": "1.0",
  "description": "Monitors high-value target assets and seamlessly links to financing solutions.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}